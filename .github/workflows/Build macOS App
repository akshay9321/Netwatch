name: Build macOS App

on:
  push:
    branches: [ main ]
  workflow_dispatch: {}

jobs:
  build:
    runs-on: macos-14
    steps:
      - uses: actions/checkout@v4

      - name: Show Swift & Xcode versions
        run: |
          swift --version
          xcodebuild -version

      - name: Build universal release binary (Intel + Apple Silicon)
        run: swift build -c release --arch x86_64 --arch arm64

      - name: Assemble .app bundle
        run: |
          chmod +x Scripts/make_app_bundle.sh
          ./Scripts/make_app_bundle.sh

      - name: Upload app artifact
        uses: actions/upload-artifact@v4
        with:
          name: NetWatch-macOS
          path: dist/NetWatch.app.zip
          retention-days: 14
